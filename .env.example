# Akzio Signal Intelligence — secret/config environment template
# Copy to `.env` (gitignored) and fill in real values. config/config.yaml
# references these via ${VAR} placeholders, expanded at load time.

# LLM gateway (required for live runs; --mock does not need it)
LLM_GATEWAY_BASE_URL=https://oneapi-comate.baidu-int.com/v1
LLM_GATEWAY_API_KEY=

# Twelve Data technical indicators
TWELVE_DATA_API_KEY=

# Jin10 flash/news feed (full URL including token)
JIN10_API_URL=

# Report email delivery (report-email --mode send)
REPORT_SMTP_USERNAME=
REPORT_SMTP_PASSWORD=
REPORT_SMTP_FROM=
REPORT_SMTP_TO=
